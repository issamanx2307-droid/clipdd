DEBUG=False
SECRET_KEY=your-super-secret-key-min-50-chars-change-this-now
DATABASE_URL=postgresql://clipdd:password@db:5432/clipdd
DB_PASSWORD=password
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=clipdd.com,www.clipdd.com,localhost

# Public URL (no trailing slash) — used for absolute video/audio links in API
SITE_URL=https://clipdd.com

# ─── AI / External APIs ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key-here
FAL_KEY=...your-fal-ai-key-here           # fal.ai dashboard → API Keys
GEMINI_API_KEY=...your-gemini-key-here    # aistudio.google.com → Get API Key

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Admin Panel ──────────────────────────────────────────────────────────────
ADMIN_PANEL_PASSWORD=change-this-secure-password

# ─── Storage (optional — leave blank to use local media volume) ───────────────
USE_S3=False
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clipdd
